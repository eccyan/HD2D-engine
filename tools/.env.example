# =============================================================================
# vulkan-game-tools AI Provider Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed.
# Run `./setup.sh` to auto-detect and configure.
# =============================================================================

# --- Ollama (LLM) -----------------------------------------------------------
# Used by: Level Designer, Keyframe Animator, Particle Designer
VITE_OLLAMA_URL=http://localhost:11434
VITE_OLLAMA_MODEL=llama3

# --- SD WebUI Forge (Stable Diffusion) ---------------------------------------
# Used by: Pixel Painter
# Recommended: SD 1.5 based model (<4GB) for pixel art
VITE_SD_WEBUI_URL=http://localhost:7860

# --- Stable Audio (optional, local AI audio) ---------------------------------
# Used by: Audio Composer, SFX Designer (optional local AI generation)
# Requires: stable-audio-server.py running locally
# Start with: cd tools && python scripts/stable-audio-server.py
# VITE_STABLE_AUDIO_URL=http://localhost:8001

# --- Replicate API (optional, cloud AI audio) --------------------------------
# Used by: Audio Composer, SFX Designer (optional — they have built-in
# procedural generation that works with zero setup)
# Get your token at: https://replicate.com/account/api-tokens
# VITE_REPLICATE_API_TOKEN=r8_your_token_here
